{
	"name": "multi-llm-copilot-provider",
	"publisher": "allgood",
	"displayName": "Multi-LLM Provider for Copilot",
	"description": "Use any LLM provider (OpenAI, Anthropic, or custom endpoints) in GitHub Copilot Chat",
	"icon": "assets/logo.png",
	"keywords": [
		"ai",
		"chat",
		"copilot",
		"github-copilot",
		"language-model",
		"llm",
		"openai",
		"anthropic",
		"openai-compatible",
		"thinking",
		"git-commit"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/OnesoftQwQ/opencode-go-copilot"
	},
	"homepage": "https://github.com/OnesoftQwQ/opencode-go-copilot",
	"bugs": {
		"url": "https://github.com/OnesoftQwQ/opencode-go-copilot/issues"
	},
	"version": "1.0.0-alpha2",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"license": "MIT",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "multiLLM",
				"displayName": "%providerDisplayName%",
				"managementCommand": "multiLLM.setApiKey"
			}
		],
		"commands": [
			{
				"command": "multiLLM.setApiKey",
				"category": "%commandCategory%",
				"title": "%command.setApiKey%"
			},
			{
				"command": "multiLLM.openSettings",
				"category": "%commandCategory%",
				"title": "%command.openSettings%"
			},
			{
				"command": "multiLLM.generateGitCommitMessage",
				"title": "%command.generateCommit%",
				"category": "%commandCategory%",
				"icon": "$(wand)"
			},
			{
				"command": "multiLLM.abortGitCommitMessage",
				"title": "%command.abortCommit%",
				"category": "%commandCategory%",
				"icon": "$(debug-stop)"
			},
			{
				"command": "multiLLM.setModelPreset",
				"category": "%commandCategory%",
				"title": "%command.setModelPreset%"
			},
			{
				"command": "multiLLM.manageProviders",
				"category": "%commandCategory%",
				"title": "%command.manageProviders%"
			},
			{
				"command": "multiLLM.rescanModels",
				"category": "%commandCategory%",
				"title": "%command.rescanModels%",
				"icon": "$(refresh)"
			}
		],
		"menus": {
			"scm/title": [
				{
					"command": "multiLLM.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !multiLLM.isGeneratingCommit"
				},
				{
					"command": "multiLLM.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && multiLLM.isGeneratingCommit"
				}
			],
			"commandPalette": [
				{
					"command": "multiLLM.generateGitCommitMessage",
					"when": "config.git.enabled && !multiLLM.isGeneratingCommit"
				},
				{
					"command": "multiLLM.abortGitCommitMessage",
					"when": "config.git.enabled && multiLLM.isGeneratingCommit"
				}
			]
		},
		"configuration": {
			"title": "%config.title%",
			"properties": {
				"multiLLM.providers": {
					"type": "array",
					"default": [
						{
							"id": "opencode-go",
							"label": "OpenCode Go",
							"baseUrl": "https://opencode.ai/zen/go/v1/",
							"apiMode": "openai",
							"group": "OpenCode Go",
							"enabled": true,
							"models": [
								{
									"id": "glm-5.1",
									"name": "GLM-5.1",
									"vision": false,
									"thinkingMode": "always",
									"contextLength": 200000,
									"maxOutputTokens": 131072
								},
								{
									"id": "glm-5",
									"name": "GLM-5",
									"vision": false,
									"thinkingMode": "always",
									"contextLength": 200000,
									"maxOutputTokens": 131072
								},
								{
									"id": "kimi-k2.5",
									"name": "Kimi K2.5",
									"vision": true,
									"thinkingMode": "always",
									"contextLength": 262144,
									"maxOutputTokens": 16384
								},
								{
									"id": "kimi-k2.6",
									"name": "Kimi K2.6",
									"vision": true,
									"thinkingMode": "always",
									"contextLength": 262144,
									"maxOutputTokens": 16384
								},
								{
									"id": "kimi-k2.7-code",
									"name": "Kimi K2.7",
									"vision": true,
									"thinkingMode": "always",
									"contextLength": 262144,
									"maxOutputTokens": 16384
								},
								{
									"id": "deepseek-v4-pro",
									"name": "DeepSeek V4 Pro",
									"vision": false,
									"thinkingMode": "switchable",
									"defaultReasoningEffort": "max",
									"supportedReasoningEfforts": [
										"high",
										"max"
									],
									"contextLength": 1000000,
									"maxOutputTokens": 393216
								},
								{
									"id": "deepseek-v4-flash",
									"name": "DeepSeek V4 Flash",
									"vision": false,
									"thinkingMode": "switchable",
									"defaultReasoningEffort": "max",
									"supportedReasoningEfforts": [
										"high",
										"max"
									],
									"contextLength": 1000000,
									"maxOutputTokens": 393216
								},
								{
									"id": "mimo-v2-pro",
									"name": "MiMo-V2-Pro",
									"vision": false,
									"thinkingMode": "always",
									"contextLength": 262144,
									"maxOutputTokens": 32768
								},
								{
									"id": "mimo-v2-omni",
									"name": "MiMo-V2-Omni",
									"vision": true,
									"thinkingMode": "always",
									"contextLength": 262144,
									"maxOutputTokens": 32768
								},
								{
									"id": "mimo-v2.5-pro",
									"name": "MiMo-V2.5-Pro",
									"vision": false,
									"thinkingMode": "switchable",
									"contextLength": 1000000,
									"maxOutputTokens": 32768
								},
								{
									"id": "mimo-v2.5",
									"name": "MiMo-V2.5",
									"vision": false,
									"thinkingMode": "switchable",
									"contextLength": 1000000,
									"maxOutputTokens": 32768
								},
								{
									"id": "minimax-m3",
									"name": "MiniMax M3",
									"vision": true,
									"thinkingMode": "adaptive",
									"apiMode": "anthropic",
									"extra": {
										"reasoning_split": true
									},
									"contextLength": 1000000,
									"maxOutputTokens": 32768
								},
								{
									"id": "minimax-m2.7",
									"name": "MiniMax M2.7",
									"vision": false,
									"thinkingMode": "always",
									"apiMode": "anthropic",
									"extra": {
										"reasoning_split": true
									},
									"contextLength": 204800,
									"maxOutputTokens": 32768
								},
								{
									"id": "minimax-m2.5",
									"name": "MiniMax M2.5",
									"vision": false,
									"thinkingMode": "always",
									"apiMode": "anthropic",
									"contextLength": 204800,
									"maxOutputTokens": 32768
								},
								{
									"id": "qwen3.7-max",
									"name": "Qwen3.7 Max",
									"vision": false,
									"thinkingMode": "switchable",
									"apiMode": "anthropic",
									"contextLength": 1000000,
									"maxOutputTokens": 65536
								},
								{
									"id": "qwen3.7-plus",
									"name": "Qwen3.7 Plus",
									"vision": true,
									"thinkingMode": "switchable",
									"apiMode": "anthropic",
									"contextLength": 1000000,
									"maxOutputTokens": 65536
								},
								{
									"id": "qwen3.6-plus",
									"name": "Qwen3.6 Plus",
									"vision": true,
									"thinkingMode": "switchable",
									"apiMode": "anthropic",
									"contextLength": 1000000,
									"maxOutputTokens": 32768
								},
								{
									"id": "qwen3.5-plus",
									"name": "Qwen3.5 Plus",
									"vision": true,
									"thinkingMode": "switchable",
									"apiMode": "anthropic",
									"contextLength": 1000000,
									"maxOutputTokens": 32768
								}
							]
						},
						{
							"id": "openai",
							"label": "OpenAI",
							"baseUrl": "https://api.openai.com/v1/",
							"apiMode": "openai",
							"group": "OpenAI",
							"enabled": false,
							"modelsBaseUrl": "https://api.openai.com/v1"
						},
						{
							"id": "anthropic",
							"label": "Anthropic",
							"baseUrl": "https://api.anthropic.com/",
							"apiMode": "anthropic",
							"group": "Anthropic",
							"enabled": false,
							"models": [
								{
									"id": "claude-sonnet-4-20250514",
									"name": "Claude Sonnet 4",
									"vision": true,
									"thinkingMode": "switchable",
									"contextLength": 200000,
									"maxOutputTokens": 8192
								}
							]
						}
					],
					"description": "%config.providers.desc%"
				},
				"multiLLM.commitLanguage": {
					"type": "string",
					"default": "auto",
					"enum": [
						"auto",
						"English",
						"French",
						"Italian",
						"German",
						"Spanish",
						"Russian",
						"Chinese (Simplified)",
						"Chinese (Traditional)",
						"Japanese",
						"Korean",
						"Czech",
						"Portuguese (Brazil)",
						"Turkish",
						"Polish"
					],
					"enumDescriptions": [
						"%config.commitLanguage.auto.desc%",
						"%config.commitLanguage.enum.English.desc%",
						"%config.commitLanguage.enum.French.desc%",
						"%config.commitLanguage.enum.Italian.desc%",
						"%config.commitLanguage.enum.German.desc%",
						"%config.commitLanguage.enum.Spanish.desc%",
						"%config.commitLanguage.enum.Russian.desc%",
						"%config.commitLanguage.enum.ChineseSimplified.desc%",
						"%config.commitLanguage.enum.ChineseTraditional.desc%",
						"%config.commitLanguage.enum.Japanese.desc%",
						"%config.commitLanguage.enum.Korean.desc%",
						"%config.commitLanguage.enum.Czech.desc%",
						"%config.commitLanguage.enum.PortugueseBrazil.desc%",
						"%config.commitLanguage.enum.Turkish.desc%",
						"%config.commitLanguage.enum.Polish.desc%"
					],
					"description": "%config.commitLanguage.desc%"
				},
				"multiLLM.commitModel": {
					"type": "string",
					"default": "opencode-go:deepseek-v4-flash",
					"description": "%config.commitModel.desc%"
				},
				"multiLLM.commitMessagePrompt": {
					"type": "string",
					"default": "",
					"description": "%config.commitMessagePrompt.desc%"
				},
				"multiLLM.requestTimeout": {
					"type": "number",
					"default": 600000,
					"minimum": 10000,
					"description": "%config.requestTimeout.desc%"
				},
				"multiLLM.recentCommitsCount": {
					"type": "number",
					"default": 10,
					"minimum": 0,
					"maximum": 50,
					"description": "%config.recentCommitsCount.desc%"
				},
				"multiLLM.commitIncludeCommitDiff": {
					"type": "boolean",
					"default": false,
					"description": "%config.commitIncludeCommitDiff.desc%"
				},
				"multiLLM.commitAttachContextFiles": {
					"type": "boolean",
					"default": true,
					"description": "%config.commitAttachContextFiles.desc%"
				},
				"multiLLM.modelPreset": {
					"type": "string",
					"default": "precise",
					"description": "%config.modelPreset.desc%",
					"editPresentation": "singlelineText"
				},
				"multiLLM.temperature": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 2,
					"description": "%config.temperature.desc%"
				},
				"multiLLM.top_p": {
					"type": "number",
					"default": null,
					"minimum": 0,
					"maximum": 1,
					"description": "%config.top_p.desc%"
				},
				"multiLLM.modelPresets": {
					"type": "array",
					"default": [
						{
							"id": "precise",
							"label": "Precise",
							"temperature": 0
						},
						{
							"id": "balanced",
							"label": "Balanced",
							"temperature": 1
						},
						{
							"id": "creative",
							"label": "Creative",
							"temperature": 1.2
						},
						{
							"id": "extra-creative",
							"label": "Extra Creative",
							"temperature": 1.7
						}
					],
					"items": {
						"type": "object",
						"required": [
							"id",
							"label",
							"temperature"
						],
						"properties": {
							"id": {
								"type": "string",
								"description": "%config.modelPreset.id.desc%"
							},
							"label": {
								"type": "string",
								"description": "%config.modelPreset.label.desc%"
							},
							"temperature": {
								"type": "number",
								"description": "%config.modelPreset.temperature.desc%"
							},
							"top_p": {
								"type": "number",
								"description": "%config.modelPreset.top_p.desc%"
							}
						}
					},
					"description": "%config.modelPresets.desc%"
				},
				"multiLLM.visionProxyModel": {
					"type": "string",
					"default": "opencode-go:qwen3.6-plus",
					"description": "%config.visionProxyModel.desc%"
				},
				"multiLLM.visionProxyThinking": {
					"type": "boolean",
					"default": false,
					"description": "%config.visionProxyThinking.desc%"
				},
				"multiLLM.enableThirdPartyTokenIndicator": {
					"type": "boolean",
					"default": true,
					"description": "%config.enableThirdPartyTokenIndicator.desc%"
				}
			}
		}
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -watch -p ./",
		"build": "npx @vscode/vsce package -o multillm-copilot.vsix",
		"postinstall": "node scripts/copy-tokenizer.js"
	},
	"dependencies": {
		"@microsoft/tiktokenizer": "^1.0.10"
	},
	"devDependencies": {
		"@eslint/js": "9.39.4",
		"@types/node": "^22",
		"@types/vscode": "^1.116.0",
		"eslint": "9.39.4",
		"typescript": "^5.9.2",
		"typescript-eslint": "8.60.1"
	}
}
